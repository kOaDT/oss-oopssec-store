---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { getChapters } from "@/utils/getRoadmapContext";
import { SITE } from "@/config";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const chapters = getChapters();
const pad = (n: number) => String(n).padStart(2, "0");

const description = `Browse OopsSec Store walkthroughs by vulnerability class: ${chapters.length} topics from reconnaissance to remote code execution.`;
---

<Layout title={`Topics | ${SITE.title}`} {description}>
  <Header />
  <Main
    pageTitle="Topics"
    pageDesc="Every walkthrough grouped by vulnerability class, following the roadmap chapters."
  >
    <ul class="topics-list">
      {
        chapters.map(chapter => (
          <li class="topics-item">
            <a href={`${base}/topics/${chapter.slug}`} class="topics-link">
              <span class="topics-num">{pad(chapter.index)}</span>
              <span class="topics-body">
                <span class="topics-title">{chapter.title}</span>
                <span class="topics-tagline">{chapter.tagline}</span>
                <span class="topics-count">
                  {chapter.slugs.length} walkthrough
                  {chapter.slugs.length === 1 ? "" : "s"}
                </span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </Main>
  <Footer />
</Layout>

<style>
  .topics-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .topics-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  .topics-link {
    display: flex;
    gap: 0.75rem;
    height: 100%;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 0.25rem;
    background: var(--background);
    color: inherit;
    text-decoration: none;
    transition:
      border-color 180ms ease,
      transform 180ms ease;
  }
  .topics-link:hover,
  .topics-link:focus-visible {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .topics-num {
    font-family: var(--font-app);
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.8;
    flex-shrink: 0;
  }
  .topics-body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }
  .topics-title {
    font-weight: 700;
    color: var(--foreground);
  }
  .topics-link:hover .topics-title,
  .topics-link:focus-visible .topics-title {
    color: var(--accent);
  }
  .topics-tagline {
    font-size: 0.85rem;
    font-style: italic;
    opacity: 0.75;
    line-height: 1.4;
  }
  .topics-count {
    font-family: var(--font-app);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.6;
  }
  @media (prefers-reduced-motion: reduce) {
    .topics-link {
      transition: none;
    }
    .topics-link:hover,
    .topics-link:focus-visible {
      transform: none;
    }
  }
</style>
